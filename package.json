{
  "name": "raccoonhouse-studio",
  "version": "1.0.7",
  "description": "RaccoonHouse Anime Dubbing Studio",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:exe": "python build-backend.py && npm run build && electron-builder --win",
    "publish": "python build-backend.py && npm run build && electron-builder --win --publish always",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dev:full": "concurrently -k -n BACKEND,APP --prefix-colors cyan,green \".venv/Scripts/python backend/run.py\" \"wait-on tcp:8765 && npm run electron:dev\""
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "zustand": "^4.5.4"
  },
  "author": "RaccoonHouse Studio",
  "devDependencies": {
    "@types/node": "^22.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.5",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
